# Shared secret — must match PROCESSOR_SECRET in the Vercel/Next.js app
PROCESSOR_SECRET=change-me-to-a-random-string

# Supabase project URL and service role key
# (SUPABASE_URL is the non-public name; NEXT_PUBLIC_SUPABASE_URL also works)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Port the Express server listens on (Railway sets this automatically)
PORT=3001
